{
  "extends": "../../tsconfig.common.json",

  "compilerOptions": {
    "outDir": "lib",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "paths": {
      "@sketch-ruler/core": ["../../../vue3-sketch-ruler/packages/core/lib/index.d.ts"],
      "@sketch-ruler/canvas": ["../../../vue3-sketch-ruler/packages/canvas/lib/index.d.ts"]
    }
  },
  "include": ["**/*.tsx", "**/*.ts", "**/*.json"]
}
